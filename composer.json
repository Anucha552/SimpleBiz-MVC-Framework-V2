{
    "name": "simplebiz/mvc-framework-v2",
    "description": "SimpleBiz MVC Framework V2 - A clean, secure, extensible MVC framework with E-Commerce foundation",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "SimpleBiz Development Team",
            "email": "dev@simplebiz.local"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
