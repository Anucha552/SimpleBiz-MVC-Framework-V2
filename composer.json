{
    "name": "simplebiz/mvc-framework-v2",
    "description": "SimpleBiz MVC Framework V2 - เฟรมเวิร์ก MVC ที่สะอาด ปลอดภัย และขยายได้ง่าย พร้อมโครงสร้างพื้นฐานสำหรับระบบอีคอมเมิร์ซ",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "mvc",
        "framework",
        "php",
        "e-commerce",
        "shopping-cart",
        "restful-api",
        "psr-4",
        "router",
        "middleware",
        "thai"
    ],
    "homepage": "https://github.com/simplebiz/mvc-framework-v2",
    "support": {
        "issues": "https://github.com/simplebiz/mvc-framework-v2/issues",
        "source": "https://github.com/simplebiz/mvc-framework-v2"
    },
    "authors": [
        {
            "name": "SimpleBiz Development Team",
            "email": "dev@simplebiz.local"
        }
    ],
    "require": {
        "php": ">=8.0",
        "twbs/bootstrap": "5.3.2",
        "vlucas/phpdotenv": "^5.6.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "modules/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
