#########################  แอปพลิเคชัน  #########################
# ชื่อแอปพลิเคชั่น
APP_NAME="SimpleBiz MVC Framework V2"
# กำหนดสภาพแวดล้อมของแอพ ตัวอย่าง: local, testing, production
# Production: ตั้งเป็น production
APP_ENV=local
# เปิดหรือปิดโหมดดีบัก (true/false) ควรตั้งเป็น false ใน production เพื่อความปลอดภัย
# Production: ตั้งเป็น false
APP_DEBUG=true
# URL ของแอป (ใช้ในการสร้างลิงก์) เช่น: http://localhost หรือ https://example.com
# Production: ใส่ URL จริงที่ใช้เข้าระบบ
APP_URL=http://localhost
# คีย์ลับสำหรับลงลายเซ็นข้อมูล (เช่น remember cookie)
# Production: ต้องเป็นค่าใหม่ที่ปลอดภัย และไม่แชร์กับระบบอื่น
APP_KEY=2a8f5d3d45d7c585289926bf9a456a95
# โซนเวลาแอป (default: UTC) ตัวอย่าง: Asia/Bangkok, America/New_York
APP_TIMEZONE=UTC
# โดเมนสำหรับ cookie (ถ้าเว้นว่างจะใช้โดเมนปัจจุบัน)
# Production: ใส่โดเมนหลัก เช่น .example.com (ถ้าต้องใช้ข้ามซับโดเมน)
APP_COOKIE_DOMAIN=
# SameSite สำหรับ remember cookie (Lax|Strict|None)
REMEMBER_SAMESITE=Lax

#########################  Logging  #########################
# ขนาดสูงสุดของไฟล์ล็อก  ตัวอย่าง: MAX_LOG_SIZE=5242880  # 5MB 
# Production: กำหนดตามพื้นที่ดิสก์ที่มี
MAX_LOG_SIZE=5242880
# จำนวนวันที่เก็บไฟล์ล็อกก่อนลบ (default: 7) ตัวอย่าง: LOG_RETENTION_DAYS=7
# Production: กำหนดตามนโยบายเก็บข้อมูล
LOG_RETENTION_DAYS=7
# เปิดการบันทึกรายละเอียดเพิ่มเติมหรือไม่ เช่น: true, false
# Production: แนะนำ false
LOG_DETAILED=false
# บันทึก request body หรือไม่ เช่น: true, false (ควรตั้งเป็น false ใน production เพื่อความปลอดภัย)
# Production: แนะนำ false
LOG_REQUEST_BODY=false

#########################  Database  #########################
# ประเภทฐานข้อมูล ตัวอย่าง: mysql, sqlite
# Production: ตั้งเป็นฐานข้อมูลที่ใช้จริง (แนะนำ mysql)
DB_CONNECTION=sqlite
# โฮสต์ของฐานข้อมูล (สำหรับ mysql)
# Production: ใส่โฮสต์จริง
DB_HOST=127.0.0.1
# พอร์ตของฐานข้อมูล (สำหรับ mysql)
# Production: ใส่พอร์ตจริง
DB_PORT=3306
# ชื่อฐานข้อมูล (สำหรับ sqlite ให้ใส่ path เช่น: storage/database.sqlite)
# Production: ใส่ชื่อฐานข้อมูลจริง
DB_DATABASE=storage/database.sqlite
# ชื่อผู้ใช้ฐานข้อมูล (สำหรับ mysql)
# Production: ใส่ผู้ใช้จริง
DB_USERNAME=root
# รหัสผ่านฐานข้อมูล (สำหรับ mysql)
# Production: ใส่รหัสผ่านจริง
DB_PASSWORD=
# ตัวเลือกเพิ่มเติมสำหรับการเชื่อมต่อฐานข้อมูล (สำหรับ mysql) เช่น: utf8mb4_unicode_ci
DB_CHARSET=utf8mb4

#########################  Mail / Email  #########################
# SMTP server ที่ใช้ส่งอีเมล เช่น: smtp.gmail.com
# Production: ใส่ SMTP จริง
MAIL_HOST=localhost
# พอร์ตของ SMTP server เช่น: 587 สำหรับ TLS, 465 สำหรับ SSL
# Production: ใส่พอร์ตจริง
MAIL_PORT=587
# ชื่อผู้ใช้สำหรับ SMTP server (ถ้าใช้การยืนยันตัวตน) เช่น: user@example.com
# Production: ใส่ผู้ใช้จริง
MAIL_USERNAME=
# รหัสผ่านสำหรับ SMTP server (ถ้าใช้การยืนยันตัวตน) เช่น: password123
# Production: ใส่รหัสผ่านจริง
MAIL_PASSWORD=
# tls หรือ ssl หรือ ว่างสำหรับไม่มีการเข้ารหัส
# Production: แนะนำ tls หรือ ssl
MAIL_ENCRYPTION=tls
# ที่อยู่อีเมลที่ใช้ในช่อง From ของอีเมลที่ส่งออก เช่น: noreply@example.com
# Production: ใส่โดเมนจริง
MAIL_FROM_ADDRESS=noreply@simplebiz.local
# ชื่อที่ใช้ในช่อง From ของอีเมลที่ส่งออก เช่น: "SimpleBiz MVC"
# Production: ใส่ชื่อแบรนด์จริง
MAIL_FROM_NAME="SimpleBiz MVC"

#########################  API / Services  #########################
# API key สำหรับการเข้าถึง API
# Production: เปลี่ยนเป็นคีย์จริงและเก็บเป็นความลับ
API_KEY=demo-api-key-12345
# ตัวอย่างการตั้งค่าหลายคีย์ คั่นด้วย comma (เช่น: key1,key2,key3)
# Production: ใส่เฉพาะคีย์ที่ใช้จริง
API_KEYS=

#########################  Security / Headers  #########################
# ความปลอดภัยของเนื้อหา (Content Security Policy)
# Production: แนะนำกำหนด CSP ให้เหมาะกับแอปของคุณ หรือเว้นว่างถ้าไม่แน่ใจ
SECURITY_CSP=
# ความปลอดภัยของการเชื่อมต่อ (HTTP Strict Transport Security)
# Production: เปิดเมื่อใช้ HTTPS จริงเท่านั้น
SECURITY_HSTS=false
# กำหนดอายุของ HSTS ในหน่วยวินาที (เช่น: 15552000 สำหรับ 180 วัน)
SECURITY_HSTS_MAX_AGE=15552000
# กำหนดให้ HSTS รวม subdomains ด้วยหรือไม่ (true/false)
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
# กำหนดให้ HSTS ถูก preload ในเบราว์เซอร์หรือไม่ (true/false)
SECURITY_HSTS_PRELOAD=false

#########################  CORS / Trusted proxies  #########################
# กำหนด origin ที่อนุญาตให้เรียก API (ใช้เฉพาะค่าที่ระบุที่นี่)
# Production: ใส่โดเมนจริงที่ต้องการอนุญาตเท่านั้น
# ถ้ามีหลายค่าให้คั่นด้วย comma เช่น: http://example.com,http://app.example.com
# ถ้าต้องการอนุญาตทุก origin ให้ใส่ * (ไม่แนะนำใน production)
CORS_ALLOWED_ORIGINS=
# IP ของ reverse proxy/load balancer ที่ไว้ใจ (คั่นด้วย comma)
# ใส่เฉพาะ IP ของ proxy ที่คุณควบคุมได้ เช่น: 10.0.0.10,10.0.0.11
APP_TRUSTED_PROXIES=

#########################  Maintenance  #########################
# เปิดหรือปิดโหมด maintenance (true/false)
# Production: ควรเป็น false ปกติ เปิดเฉพาะช่วงบำรุงรักษา
MAINTENANCE_MODE=false
# IP ที่ได้รับยกเว้นขณะ maintenance เช่น: 127.0.0.1,::1
MAINTENANCE_ALLOWED_IPS=
# เวลาคาดว่าจะกลับมาให้บริการ (แสดงบนหน้า maintenance), เช่น: "2026-02-19 12:00"
MAINTENANCE_RETRY_AFTER=

#########################  Auth / Redirects  #########################
# URL ที่ผู้ใช้ที่ไม่ได้ล็อกอินจะถูกเปลี่ยนเส้นทางไป (เช่น: /login)
# Production: ใส่ URL จริงสำหรับหน้าเข้าสู่ระบบ
GUEST_REDIRECT_TO=/
# URL ที่ผู้ใช้ที่เข้าสู่ระบบแล้วจะถูกเปลี่ยนเส้นทางไป (เช่น: /dashboard)
# Production: ใส่ URL จริงสำหรับหน้าแดชบอร์ดหรือหน้าหลักหลังเข้าสู่ระบบ
AUTH_REDIRECT_TO=/
