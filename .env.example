#########################  แอปพลิเคชัน  #########################
# ชื่อแอป ส่วนที่เรียกใช้ใน config/app.php (L22)
APP_NAME="SimpleBiz MVC Framework V2"
# ตัวอย่าง: local, testing, production ส่วนที่เรียกใช้ใน config/app.php (L23), app/Core/Session.php (L78), app/Views/errors/500.php (L75)
APP_ENV=local
# true = แสดงรายละเอียดข้อผิดพลาด (อย่าเปิดใน production) ส่วนที่เรียกใช้ใน config/app.php (L24)
APP_DEBUG=true
# URL ของแอป (ใช้ในการสร้างลิงก์) ส่วนที่เรียกใช้ใน config/app.php (L25)
APP_URL=http://localhost
# ส่วนที่เรียกใช้ใน (ไม่พบการเรียกใช้ในโค้ด)
APP_KEY=457d9598572b705b8e4fb9891ea72432

#########################  Logging  #########################
# ขนาดสูงสุดของไฟล์ล็อก  ตัวอย่าง: MAX_LOG_SIZE=5242880  # 5MB 
MAX_LOG_SIZE=100000
# จำนวนวันที่เก็บไฟล์ล็อกก่อนลบ (default: 7)
LOG_RETENTION_DAYS=2

#########################  Database  #########################
# ส่วนที่เรียกใช้ใน config/database.php (L25)
DB_CONNECTION=mysql
# ส่วนที่เรียกใช้ใน config/database.php (L26)
DB_HOST=127.0.0.1
# ส่วนที่เรียกใช้ใน config/database.php (L27)
DB_PORT=3306
# ส่วนที่เรียกใช้ใน config/database.php (L28)
DB_DATABASE=my_app_db
# ส่วนที่เรียกใช้ใน config/database.php (L29)
DB_USERNAME=root
# ส่วนที่เรียกใช้ใน config/database.php (L30)
DB_PASSWORD=

#########################  Mail / Email  #########################
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L77)
MAIL_HOST=localhost
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L78)
MAIL_PORT=587
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L79)
MAIL_USERNAME=
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L80)
MAIL_PASSWORD=
# tls หรือ ssl หรือ ว่าง ส่วนที่เรียกใช้ใน app/Core/Mail.php (L81)
MAIL_ENCRYPTION=tls
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L72)
MAIL_FROM_ADDRESS=noreply@simplebiz.local
# ส่วนที่เรียกใช้ใน app/Core/Mail.php (L73)
MAIL_FROM_NAME="SimpleBiz MVC"

#########################  API / Services  #########################
# ส่วนที่เรียกใช้ใน app/Middleware/ApiKeyMiddleware.php (L78)
API_KEY=demo-api-key-12345
# ตัวอย่างการตั้งค่าหลายคีย์ คั่นด้วย comma ส่วนที่เรียกใช้ใน app/Middleware/ApiKeyMiddleware.php (L80)
# API_KEYS=key1,key2,key3

#########################  Security / Headers  #########################
# ส่วนที่เรียกใช้ใน app/Middleware/SecurityHeadersMiddleware.php (L38)
SECURITY_CSP=
# ส่วนที่เรียกใช้ใน app/Middleware/SecurityHeadersMiddleware.php (L47)
SECURITY_HSTS=false
# ส่วนที่เรียกใช้ใน app/Middleware/SecurityHeadersMiddleware.php (L49)
SECURITY_HSTS_MAX_AGE=15552000
# ส่วนที่เรียกใช้ใน app/Middleware/SecurityHeadersMiddleware.php (L50)
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
# ส่วนที่เรียกใช้ใน app/Middleware/SecurityHeadersMiddleware.php (L51)
SECURITY_HSTS_PRELOAD=false

#########################  CORS / Trusted proxies  #########################
# ถ้ามีหลายค่าให้คั่นด้วย comma เช่น: http://example.com,http://app.example.com
# ส่วนที่เรียกใช้ใน app/Middleware/CorsMiddleware.php (L102)
CORS_ALLOWED_ORIGINS=

#########################  Maintenance / Operations  #########################
# true = เปิดโหมดปรับปรุง (Maintenance) ส่วนที่เรียกใช้ใน app/Middleware/MaintenanceMiddleware.php (L113)
MAINTENANCE_MODE=false
# IP ที่ได้รับยกเว้นขณะ maintenance ส่วนที่เรียกใช้ใน app/Middleware/MaintenanceMiddleware.php (L71)
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1
