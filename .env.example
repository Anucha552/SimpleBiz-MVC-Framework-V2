# ENVIRONMENT CONFIGURATION
# 
# Purpose: Store environment-specific configuration
# IMPORTANT: Never commit this file with real credentials!
#
# Copy this file to .env and update with your settings

# Application
APP_NAME="SimpleBiz MVC Framework V2"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Database
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=simplebiz_mvc
DB_USERNAME=root
DB_PASSWORD=

# API Keys
# Generate secure keys for production: https://randomkeygen.com/
API_KEY=demo-api-key-12345

# Security
# In production, use strong random session keys
SESSION_LIFETIME=7200

# Logging
LOG_LEVEL=info
