# การตั้งค่าสภาพแวดล้อม
# 
# จุดประสงค์: เก็บค่าคอนฟิกเฉพาะแต่ละสภาพแวดล้อม
# สำคัญ: ห้าม commit ไฟล์นี้พร้อมข้อมูลการเข้าถึงจริง!
#
# คัดลอกไฟล์นี้ไปเป็น .env และอัปเดตด้วยค่าคอนฟิกของคุณ

# แอปพลิเคชัน
APP_NAME="SimpleBiz MVC Framework V2"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# ฐานข้อมูล
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=simplebiz_mvc
DB_USERNAME=root
DB_PASSWORD=

# API Keys
# สร้าง key ที่ปลอดภัยสำหรับสภาพแวดล้อมจริง: https://randomkeygen.com/
API_KEY=demo-api-key-12345

# ความปลอดภัย
# ในสภาพแวดล้อมจริง ใช้ session key แบบสุ่มที่แข็งแรง
SESSION_LIFETIME=7200

# การบันทึก
LOG_LEVEL=info

# Email Configuration
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@simplebiz.local
MAIL_FROM_NAME="SimpleBiz MVC"
