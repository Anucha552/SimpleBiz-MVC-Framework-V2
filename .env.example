# .env.example - ตัวอย่างตัวแปรสภาพแวดล้อม (ภาษาไทย)
# ===================================================
# วิธีใช้:
# 1) คัดลอกไฟล์นี้เป็น `.env`
# 2) แก้ค่าให้เหมาะกับเครื่องหรือสภาพแวดล้อม (local, staging, production)
# 3) ห้ามเก็บความลับจริงไว้ใน repo (เช่น รหัสผ่าน/คีย์) — เก็บเฉพาะใน .env ที่ไม่ถูก commit

#########################  แอปพลิเคชัน (App)  #########################
# ระบุสภาพแวดล้อมของแอป: local, testing, staging, production
APP_NAME="SimpleBiz MVC Framework V2"   # ชื่อแอป (แสดงผล/log)
APP_ENV=local                            # ตัวอย่าง: local, testing, production
APP_DEBUG=true                           # true = แสดงรายละเอียดข้อผิดพลาด (อย่าเปิดใน production)
APP_URL=http://localhost                 # URL ของแอป (ใช้ในการสร้างลิงก์)
APP_KEY=                                 # คีย์สำหรับการเข้ารหัส/เซสชัน (สร้างเมื่อ deploy)

#########################  Logging  #########################
# ระดับการบันทึก: debug, info, notice, warning, error
LOG_LEVEL=debug
# ขนาดสูงสุดของไฟล์ล็อก (หน่วยเป็น bytes). ตั้งเป็น 0 เพื่อปิดการหมุนตามขนาด
# ตัวอย่าง: MAX_LOG_SIZE=5242880  # 5MB
MAX_LOG_SIZE=0
# จำนวนวันที่เก็บไฟล์ล็อกก่อนลบ (default: 7)
LOG_RETENTION_DAYS=7

#########################  Database  #########################
# DB_CONNECTION: mysql, sqlite
# - ถ้าใช้ sqlite ในเครื่องทดสอบ: set DB_CONNECTION=sqlite และ DB_DATABASE=:/absolute/path/db.sqlite หรือ :memory:
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simplebiz_mvc
DB_USERNAME=root
DB_PASSWORD=

#########################  Cache  #########################
# CACHE_DRIVER: file, memory, redis
CACHE_DRIVER=file
CACHE_PATH=storage/cache

#########################  Session  #########################
# SESSION_DRIVER: file, cookie, redis
SESSION_DRIVER=file
SESSION_COOKIE=_sb_session     # ชื่อคุกกี้ session
SESSION_LIFETIME=7200          # เวลาเป็นวินาที (default: 2 ชั่วโมง)

#########################  Mail / Email  #########################
# ตัวอย่างการตั้งค่า SMTP สำหรับส่งเมล
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls            # tls หรือ ssl หรือ ว่าง
MAIL_FROM_ADDRESS=noreply@simplebiz.local
MAIL_FROM_NAME="SimpleBiz MVC"

#########################  Queue  #########################
# QUEUE_DRIVER: sync, database, redis
QUEUE_DRIVER=sync

#########################  API / Services  #########################
# ตัวอย่าง API key สำหรับพัฒนาเท่านั้น (อย่าใช้คีย์จริงใน repo)
API_KEY=demo-api-key-12345

#########################  Security / Headers  #########################
# การตั้งค่าความปลอดภัยเพิ่มเติม (ใช้ 'true'/'false')
SECURITY_CSP=
SECURITY_HSTS=false
SECURITY_HSTS_MAX_AGE=15552000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=false
SECURITY_HSTS_PRELOAD=false

#########################  CORS / Trusted proxies  #########################
# ถ้ามีหลายค่าให้คั่นด้วย comma เช่น: http://example.com,http://app.example.com
CORS_ALLOWED_ORIGINS=
TRUSTED_PROXIES=

#########################  Maintenance / Operations  #########################
MAINTENANCE_MODE=false                 # true = เปิดโหมดปรับปรุง (Maintenance)
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1  # IP ที่ได้รับยกเว้นขณะ maintenance

#########################  Test helpers  #########################
# แนะนำสำหรับ CI / PHPUnit: ตั้ง APP_ENV=testing และ DB_CONNECTION=sqlite กับ DB_DATABASE=:memory:
# ตัวอย่าง (ไม่ต้องใส่ใน repo จริง):
# APP_ENV=testing
# DB_CONNECTION=sqlite
# DB_DATABASE=:memory:

# หมายเหตุสุดท้าย:
# - คัดลอกไฟล์นี้เป็น `.env` และแก้ค่าตามสภาพแวดล้อมของคุณ
# - ตรวจสอบให้แน่ใจว่าไฟล์ `.env` ถูกเพิ่มใน .gitignore เพื่อไม่ให้ข้อมูลลับถูก commit
