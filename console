    private function tailLogs(array $args = []): void
    {
        $lines = isset($args[0]) && is_numeric($args[0]) ? (int)$args[0] : 50;
        $logFile = __DIR__ . '/storage/logs/app.log';
        
        if (!file_exists($logFile)) {
            $this->error("ไม่พบไฟล์ log: app.log");
            return;
        }
        
        $this->info("กำลังแสดง {$lines} บรรทัดล่าสุดจาก app.log...");
        echo str_repeat("─", 80) . "\n";
        
        // Read last N lines
        $file = new SplFileObject($logFile, 'r');
        $file->seek(PHP_INT_MAX);
        $lastLine = $file->key();
        $startLine = max(0, $lastLine - $lines);
        
        $file->seek($startLine);
        while (!$file->eof()) {
            $line = $file->current();
            
            // Color code based on log level
            if (strpos($line, 'ERROR') !== false) {
                echo Color::RED . $line . Color::RESET;
            } elseif (strpos($line, 'WARNING') !== false) {
                echo Color::YELLOW . $line . Color::RESET;
            } elseif (strpos($line, 'INFO') !== false) {
                echo Color::BLUE . $line . Color::RESET;
            } else {
                echo $line;
            }
            
            $file->next();
        }
        
        echo str_repeat("─", 80) . "\n";
        $this->success("แสดง logs เรียบร้อยแล้ว");
    }
    
