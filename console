<?php
/**
 * Console Command Runner
 * 
 * จุดประสงค์: รันคำสั่ง CLI ต่างๆ สำหรับจัดการ Framework Base
 */

// ตรวจสอบว่าติดตั้ง Composer dependencies แล้วหรือยัง
if (!file_exists(__DIR__ . '/vendor/autoload.php')) {
    echo "\033[31m"; // สีแดง
    echo "[ERROR] ไม่พบไฟล์ vendor/autoload.php\n\n";
    echo "\033[33m"; // สีเหลือง
    echo "กรุณารันคำสั่งนี้ก่อน:\n";
    echo "\033[36m"; // สีฟ้า
    echo "  composer install\n\n";
    echo "\033[37m"; // สีขาว
    echo "หรือถ้ายังไม่ติดตั้ง Composer สามารถดาวน์โหลดได้ที่:\n";
    echo "  https://getcomposer.org/download/\n";
    echo "\033[0m"; // รีเซ็ตสี
    exit(1);
}

// โหลด Composer autoload
require_once __DIR__ . '/vendor/autoload.php';

// Load MigrationRunner explicitly
if (file_exists(__DIR__ . '/app/Core/MigrationRunner.php')) {
    require_once __DIR__ . '/app/Core/MigrationRunner.php';
}

// ตั้งค่า UTF-8 encoding สำหรับทุกระบบปฏิบัติการ
// เนื่องจาก Framework นี้ออกแบบมาสำหรับภาษาไทย
if (strtoupper(substr(PHP_OS, 0, 3)) === 'WIN') {
    // Windows: ตั้งค่า code page เป็น UTF-8 (65001)
    system('chcp 65001 > nul 2>&1');
} else {
    // Linux/Mac: ตั้งค่า locale เป็น UTF-8
    setlocale(LC_ALL, 'en_US.UTF-8', 'C.UTF-8', 'UTF-8');
    
    // บังคับ terminal ใช้ UTF-8
    putenv('LANG=en_US.UTF-8');
    putenv('LC_ALL=en_US.UTF-8');
}

// ตั้งค่า PHP encoding เป็น UTF-8 ทุกระบบ
if (function_exists('mb_internal_encoding')) {
    mb_internal_encoding('UTF-8');
}

// ตั้งค่า HTTP output เป็น UTF-8
if (function_exists('mb_http_output')) {
    mb_http_output('UTF-8');
}

// ตั้งค่า default charset เป็น UTF-8
ini_set('default_charset', 'UTF-8');

// โหลด environment variables
if (file_exists(__DIR__ . '/.env')) {
    // อ่านไฟล์ .env ทีละบรรทัด และข้ามบรรทัดว่างหรือ comment
    $lines = file(__DIR__ . '/.env', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    foreach ($lines as $line) {
        // ข้ามบรรทัดที่เป็น comment (ขึ้นต้นด้วย #)
        if (strpos(trim($line), '#') === 0) continue;
        // แยก key=value และเก็บเข้า environment variables
        if (strpos($line, '=') !== false) {
            list($key, $value) = explode('=', $line, 2);
            putenv(trim($key) . '=' . trim($value));
        }
    }
}

/**
 * คลาส Color - เก็บรหัสสี ANSI สำหรับแสดงผลใน terminal
 * ใช้สำหรับทำให้ข้อความมีสี และเน้นข้อความสำคัญ
 */
class Color {
    const RESET = "\033[0m";
    const RED = "\033[31m";
    const GREEN = "\033[32m";
    const YELLOW = "\033[33m";
    const BLUE = "\033[34m";
    const CYAN = "\033[36m";
    const WHITE = "\033[37m";
    const GRAY = "\033[90m";
    const BOLD = "\033[1m";
}

/**
 * คลาส Console - หัวใจหลักของระบบ CLI
 * จุดประสงค์:
 * - จัดการและรันคำสั่ง CLI ทั้งหมด
 * - ตรวจสอบและ validate ระบบ
 * - สร้างและจัดการ project files
 * - รัน migrations, seeders, และ tests
 */
class Console
{
    /** @var array รายการคำสั่งทั้งหมดที่มีในระบบ (command => method) */
    private array $commands = [];
    
    /**
     * Constructor - เริ่มต้น console และลงทะเบียนคำสั่งทั้งหมด
     */
    public function __construct()
    {
        $this->registerCommands();
    }
    
    /**
     * ลงทะเบียนคำสั่งทั้งหมดพร้อม aliases
     * แมป command name กับ method ที่จะถูกเรียก
     */
    private function registerCommands(): void
    {
        $this->commands = [
            'check' => 'checkEnvironment',
            'setup' => 'setupProject',
            'serve' => 'runServer',
            'migrate' => 'runMigrations',
            'migrate:rollback' => 'rollbackMigrations',
            'migrate:fresh' => 'freshMigrations',
            'migrate:reset' => 'resetMigrations',
            'migrate:refresh' => 'refreshMigrations',
            'migrate:status' => 'statusMigrations',
            'migrate:create' => 'createMigration',
            'migrate:modules' => 'showMigrationModules',
            'seed' => 'runSeeders',
            'db:show' => 'showDatabaseTables',
            'db:table' => 'showTableStructure',
            'cache:clear' => 'clearCache',
            'cache:warm' => 'warmCache',
            'config:cache' => 'cacheConfig',
            'view:cache' => 'cacheViews',
            'log:clear' => 'clearLogs',
            'log:tail' => 'tailLogs',
            'down' => 'enableMaintenanceMode',
            'up' => 'disableMaintenanceMode',
            'make:controller' => 'makeController',
            'make:model' => 'makeModel',
            'make:middleware' => 'makeMiddleware',
            'make:seeder' => 'makeSeeder',
            'make:test' => 'makeTest',
            'route:list' => 'listRoutes',
            'key:generate' => 'generateKey',
            'optimize' => 'optimizeApp',
            'optimize:clear' => 'clearOptimization',
            'test' => 'runTests',
            'test:unit' => 'runUnitTests',
            'test:feature' => 'runFeatureTests',
            'help' => 'showHelp',
            
            // Command Aliases
            'm' => 'runMigrations',
            'm:r' => 'rollbackMigrations',
            'm:f' => 'freshMigrations',
            'm:reset' => 'resetMigrations',
            'm:refresh' => 'refreshMigrations',
            'm:s' => 'statusMigrations',
            'm:c' => 'createMigration',
            's' => 'runServer',
            'c:c' => 'clearCache',
            't' => 'runTests',
            't:u' => 'runUnitTests',
            't:f' => 'runFeatureTests',
        ];
    }
    
    /**
     * รันคำสั่งที่ระบุจาก command line
     * @param array $argv อาร์เรย์ของ arguments จาก command line
     */
    public function run(array $argv): void
    {
        // แสดง banner ของ framework
        $this->printBanner();
        
        // ถ้าไม่มี command แสดง help
        if (count($argv) < 2) {
            $this->showHelp();
            return;
        }
        
        // แยก command และ arguments
        $command = $argv[1];
        $args = array_slice($argv, 2);
        
        if (!isset($this->commands[$command])) {
            $this->error("ไม่พบคำสั่ง '{$command}'");
            
            // แนะนำคำสั่งที่ใกล้เคียง
            $suggestions = $this->findSimilarCommands($command);
            if (!empty($suggestions)) {
                echo "\n" . Color::YELLOW . "คุณหมายถึง:" . Color::RESET . "\n";
                foreach ($suggestions as $suggestion) {
                    echo "  " . Color::CYAN . $suggestion . Color::RESET . "\n";
                }
            }
            
            $this->info("รันคำสั่ง 'php console help' เพื่อดูรายการคำสั่งที่มี \n");
            exit(1);
        }
        
        $method = $this->commands[$command];
        $this->$method($args);
    }
    
    private function checkEnvironment(array $args): void
    {
        echo Color::CYAN . Color::BOLD . "\n[CHECK] SimpleBiz Framework - ตรวจสอบสภาพแวดล้อม\n" . Color::RESET;
        echo Color::WHITE . "กำลังตรวจสอบความพร้อมของระบบ...\n" . Color::RESET;
        echo "\n";
        
        $passed = 0;
        $failed = 0;
        $warnings = 0;
        
        // 1. ตรวจสอบ PHP Version
        echo Color::YELLOW . "━━━ PHP Environment ━━━\n" . Color::RESET;
        $phpVersion = PHP_VERSION;
        $requiredVersion = '8.0.0';
        if (version_compare($phpVersion, $requiredVersion, '>=')) {
            $this->success("PHP Version: $phpVersion (ต้องการ >= $requiredVersion)");
            $passed++;
        } else {
            $this->error("PHP Version: $phpVersion (ต้องการ >= $requiredVersion)");
            $failed++;
        }
        
        // 2. ตรวจสอบ PHP Extensions
        $requiredExtensions = ['pdo', 'pdo_mysql', 'mbstring', 'json', 'openssl', 'fileinfo'];
        $optionalExtensions = ['curl', 'gd', 'zip'];
        
        echo "\n";
        foreach ($requiredExtensions as $ext) {
            if (extension_loaded($ext)) {
                $this->success("Extension: $ext");
                $passed++;
            } else {
                $this->error("Extension: $ext (จำเป็น)");
                $failed++;
            }
        }
        
        foreach ($optionalExtensions as $ext) {
            if (extension_loaded($ext)) {
                $this->success("Extension: $ext (แนะนำ)");
                $passed++;
            } else {
                $this->warning("Extension: $ext (แนะนำ - ไม่บังคับ)");
                $warnings++;
            }
        }
        
        // 3. ตรวจสอบ Composer
        echo "\n" . Color::YELLOW . "━━━ Dependencies ━━━\n" . Color::RESET;
        if (file_exists(__DIR__ . '/vendor/autoload.php')) {
            $this->success("Composer dependencies: ติดตั้งแล้ว");
            $passed++;
        } else {
            $this->error("Composer dependencies: ยังไม่ติดตั้ง");
            $this->info("  กรุณารัน: composer install");
            $failed++;
        }
        
        // ตรวจสอบ composer.json
        if (file_exists(__DIR__ . '/composer.json')) {
            $this->success("composer.json: พบแล้ว");
            $passed++;
        } else {
            $this->error("composer.json: ไม่พบ");
            $failed++;
        }
        
        // 4. ตรวจสอบไฟล์และโฟลเดอร์
        echo "\n" . Color::YELLOW . "━━━ Files & Directories ━━━\n" . Color::RESET;
        
        $requiredDirs = [
            'app' => 'โฟลเดอร์ Application',
            'config' => 'โฟลเดอร์ Configuration',
            'database' => 'โฟลเดอร์ Database',
            'public' => 'โฟลเดอร์ Public',
            'routes' => 'โฟลเดอร์ Routes',
            'storage' => 'โฟลเดอร์ Storage',
        ];
        
        foreach ($requiredDirs as $dir => $desc) {
            if (is_dir(__DIR__ . '/' . $dir)) {
                $this->success("$desc ($dir/)");
                $passed++;
            } else {
                $this->error("$desc ($dir/) - ไม่พบ");
                $failed++;
            }
        }
        
        // 5. ตรวจสอบ Permissions
        echo "\n" . Color::YELLOW . "━━━ Permissions ━━━\n" . Color::RESET;
        
        $writableDirs = ['storage', 'storage/cache', 'storage/logs'];
        foreach ($writableDirs as $dir) {
            $path = __DIR__ . '/' . $dir;
            if (is_dir($path) && is_writable($path)) {
                $this->success("$dir/ - เขียนได้");
                $passed++;
            } else {
                if (!is_dir($path)) {
                    mkdir($path, 0755, true);
                    if (is_writable($path)) {
                        $this->success("$dir/ - สร้างและตั้งค่าสิทธิ์แล้ว");
                        $passed++;
                    } else {
                        $this->error("$dir/ - สร้างไม่ได้หรือเขียนไม่ได้");
                        $failed++;
                    }
                } else {
                    $this->error("$dir/ - เขียนไม่ได้");
                    $this->info("  chmod 755 $dir");
                    $failed++;
                }
            }
        }
        
        // 6. ตรวจสอบ Configuration
        echo "\n" . Color::YELLOW . "━━━ Configuration ━━━\n" . Color::RESET;
        
        if (file_exists(__DIR__ . '/.env')) {
            $this->success(".env: พบแล้ว");
            $passed++;
            
            // ตรวจสอบค่าสำคัญใน .env
            $envContent = file_get_contents(__DIR__ . '/.env');
            if (strpos($envContent, 'APP_KEY=') !== false && preg_match('/APP_KEY=.{16,}/', $envContent)) {
                $this->success("APP_KEY: ตั้งค่าแล้ว");
                $passed++;
            } else {
                $this->warning("APP_KEY: ยังไม่ตั้งค่าหรือสั้นเกินไป");
                $this->info("  รัน: php console key:generate");
                $warnings++;
            }
        } else {
            $this->warning(".env: ไม่พบ");
            $this->info("  รัน: php console setup หรือ copy .env.example");
            $warnings++;
        }
        
        if (file_exists(__DIR__ . '/.env.example')) {
            $this->success(".env.example: พบแล้ว");
            $passed++;
        } else {
            $this->warning(".env.example: ไม่พบ");
            $warnings++;
        }
        
        // 7. ตรวจสอบ Database Connection (ถ้ามี .env)
        if (file_exists(__DIR__ . '/.env')) {
            echo "\n" . Color::YELLOW . "━━━ Database ━━━\n" . Color::RESET;
            try {
                $config = [];
                $lines = file(__DIR__ . '/.env', FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
                foreach ($lines as $line) {
                    if (strpos(trim($line), '#') === 0) continue;
                    if (strpos($line, '=') !== false) {
                        list($key, $value) = explode('=', $line, 2);
                        $config[trim($key)] = trim($value);
                    }
                }
                
                if (isset($config['DB_HOST'], $config['DB_DATABASE'])) {
                    $this->info("Database Config: พบการตั้งค่า");
                    $this->info("  Host: " . ($config['DB_HOST'] ?? 'ไม่ระบุ'));
                    $this->info("  Database: " . ($config['DB_DATABASE'] ?? 'ไม่ระบุ'));
                    $passed++;
                } else {
                    $this->warning("Database Config: ยังไม่ครบถ้วน");
                    $warnings++;
                }
            } catch (\Exception $e) {
                $this->warning("Database Config: ไม่สามารถอ่านได้");
                $warnings++;
            }
        }
        
        // 8. ตรวจสอบ Routes
        echo "\n" . Color::YELLOW . "━━━ Routes ━━━\n" . Color::RESET;
        if (file_exists(__DIR__ . '/routes/web.php')) {
            $this->success("routes/web.php: พบแล้ว");
            $passed++;
        } else {
            $this->error("routes/web.php: ไม่พบ");
            $failed++;
        }
        
        if (file_exists(__DIR__ . '/routes/api.php')) {
            $this->success("routes/api.php: พบแล้ว");
            $passed++;
        } else {
            $this->warning("routes/api.php: ไม่พบ (ไม่บังคับ)");
            $warnings++;
        }
        
        // สรุปผล
        echo "\n" . Color::CYAN . "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n" . Color::RESET;
        echo Color::BOLD . "สรุปผลการตรวจสอบ:\n" . Color::RESET;
        echo Color::GREEN . "  [OK] ผ่าน: $passed รายการ\n" . Color::RESET;
        if ($warnings > 0) {
            echo Color::YELLOW . "  [!] คำเตือน: $warnings รายการ\n" . Color::RESET;
        }
        if ($failed > 0) {
            echo Color::RED . "  [X] ล้มเหลว: $failed รายการ\n" . Color::RESET;
        }
        echo "\n";
        
        if ($failed > 0) {
            echo Color::RED . "[ERROR] ระบบยังไม่พร้อมใช้งาน\n" . Color::RESET;
            echo Color::WHITE . "กรุณาแก้ไขปัญหาที่พบก่อนเริ่มใช้งาน\n" . Color::RESET;
            exit(1);
        } elseif ($warnings > 0) {
            echo Color::YELLOW . "[WARNING] ระบบพร้อมใช้งาน แต่มีข้อแนะนำบางอย่าง\n" . Color::RESET;
            echo Color::WHITE . "แนะนำให้แก้ไขตามคำเตือนเพื่อประสิทธิภาพสูงสุด\n" . Color::RESET;
        } else {
            echo Color::GREEN . "[READY] ระบบพร้อมใช้งานทั้งหมด!\n" . Color::RESET;
            echo "\n";
        }
    }
    
    private function setupProject(array $args): void
    {
        $this->info("[SETUP] SimpleBiz Framework Project Setup");
        echo "\n";
        
        // 1. ถามชื่อโปรเจค
        echo Color::CYAN . "ชื่อโปรเจค (เช่น mybookstore, restaurant-ordering): " . Color::RESET;
        $projectName = trim(fgets(STDIN));
        
        if (empty($projectName)) {
            $this->error("กรุณาระบุชื่อโปรเจค!");
            return;
        }

        // ถามว่าจะเปลี่ยนชื่อโฟลเดอร์โปรเจคด้วยไหม (ทำตอนท้ายสุดของ setup)
        $shouldRenameFolder = false;
        $currentFolderPath = realpath(__DIR__) ?: __DIR__;
        $currentFolderName = basename($currentFolderPath);

        // อนุญาตเฉพาะชื่อที่ปลอดภัยสำหรับโฟลเดอร์ (กัน / \ : * ? " < > | และช่องว่าง)
        $isSafeFolderName = (bool) preg_match('/^[a-zA-Z0-9][a-zA-Z0-9_-]*$/', $projectName);

        if ($isSafeFolderName && $currentFolderName !== $projectName) {
            echo Color::YELLOW . "ต้องการเปลี่ยนชื่อโฟลเดอร์จาก '{$currentFolderName}' เป็น '{$projectName}' หรือไม่? (y/n) [n]: " . Color::RESET;
            $renameAnswer = strtolower(trim(fgets(STDIN)));
            $shouldRenameFolder = in_array($renameAnswer, ['y', 'yes', 'ใช่'], true);
        } elseif (!$isSafeFolderName) {
            $this->warning("ชื่อโปรเจคมีอักขระที่ไม่เหมาะกับชื่อโฟลเดอร์ จึงจะไม่เปลี่ยนชื่อโฟลเดอร์อัตโนมัติ");
        }
        
        // 2. ถามคำอธิบายโปรเจค
        echo Color::CYAN . "คำอธิบายโปรเจค: " . Color::RESET;
        $projectDescription = trim(fgets(STDIN));
        
        // 3. ถามชื่อ Vendor/Company
        echo Color::CYAN . "Vendor/Company name (เช่น mycompany): " . Color::RESET;
        $vendorName = trim(fgets(STDIN));
        
        if (empty($vendorName)) {
            $vendorName = 'mycompany';
        }
        
        // 4. ถามชื่อแอปพลิเคชัน (สำหรับแสดงผล)
        echo Color::CYAN . "ชื่อแอปพลิเคชัน (สำหรับแสดงผล เช่น My Bookstore): " . Color::RESET;
        $appName = trim(fgets(STDIN));
        
        if (empty($appName)) {
            $appName = ucwords(str_replace(['-', '_'], ' ', $projectName));
        }
        
        // 5. ถามชื่อ Database
        echo Color::CYAN . "ชื่อ Database (ถ้าไม่ระบุจะใช้ชื่อโปรเจค): " . Color::RESET;
        $dbName = trim(fgets(STDIN));
        
        if (empty($dbName)) {
            $dbName = str_replace(['-', ' '], '_', strtolower($projectName));
        }
        
        // 6. ถาม Database Username
        echo Color::CYAN . "Database Username [root]: " . Color::RESET;
        $dbUser = trim(fgets(STDIN));
        
        if (empty($dbUser)) {
            $dbUser = 'root';
        }
        
        // 7. ถาม Database Password
        echo Color::CYAN . "Database Password [เว้นว่าง]: " . Color::RESET;
        $dbPassword = trim(fgets(STDIN));
        
        echo "\n";
        
        // 8. ถามเกี่ยวกับ Git Repository
        echo Color::YELLOW . "ต้องการจัดการ Git repository หรือไม่? (y/n) [n]: " . Color::RESET;
        $manageGit = strtolower(trim(fgets(STDIN)));
        
        $gitMode = '';
        $gitRemoteUrl = '';
        
        if ($manageGit === 'y' || $manageGit === 'yes') {
            echo Color::YELLOW . "\nเลือกวิธีการ:\n" . Color::RESET;
            echo Color::WHITE . "  1. เปลี่ยน remote URL (เก็บประวัติ commits เดิม)\n" . Color::RESET;
            echo Color::WHITE . "  2. เริ่ม Git ใหม่ทั้งหมด (ลบประวัติเก่า)\n" . Color::RESET;
            echo Color::CYAN . "เลือก (1/2) [1]: " . Color::RESET;
            $gitChoice = trim(fgets(STDIN));
            
            if ($gitChoice === '2') {
                $gitMode = 'reinit';
            } else {
                $gitMode = 'change-remote';
            }
            
            echo Color::CYAN . "GitHub Repository URL (เช่น https://github.com/yourusername/yourrepo.git): " . Color::RESET;
            $gitRemoteUrl = trim(fgets(STDIN));
        }
        
        echo "\n";
        $this->info("กำลังตั้งค่าโปรเจค...");
        echo "\n";
        
        // 9. แก้ไข composer.json
        $this->info("1. กำลังแก้ไข composer.json...");
        $this->updateComposerJson($vendorName, $projectName, $projectDescription);
        
        // 10. สร้าง .env จาก .env.example
        $this->info("2. กำลังสร้างไฟล์ .env...");
        $this->createEnvFile($appName, $dbName, $dbUser, $dbPassword);
        
        // 11. สร้าง APP_KEY
        $this->info("3. กำลังสร้าง APP_KEY...");
        $appKey = $this->generateAppKey();
        $this->updateEnvKey($appKey);
        
        $step = 4;
        
        // 12. อัปเดต README.md
        $this->info("{$step}. กำลังอัปเดต README.md...");
        $this->updateReadme($projectName, $appName, $projectDescription);
        $step++;
        
        // 13. อัปเดต .gitignore
        $this->info("{$step}. กำลังตรวจสอบ .gitignore...");
        $this->ensureGitignore();
        $step++;
        
        // 14. จัดการ Git (ถ้าต้องการ)
        if (!empty($gitRemoteUrl)) {
            $this->info("{$step}. กำลังจัดการ Git repository...");
            if ($gitMode === 'reinit') {
                $this->reinitGit($gitRemoteUrl);
            } else {
                $this->changeGitRemote($gitRemoteUrl);
            }
            $step++;
        }
        
        // 15. อัปเดต Composer dependencies
        $this->info("{$step}. กำลังอัปเดต Composer dependencies...");
        passthru("composer update --quiet");
        $step++;
        
        // 16. Commit การเปลี่ยนแปลง (ถ้ามี Git)
        if (!empty($gitRemoteUrl) && is_dir(__DIR__ . '/.git')) {
            echo "\n";
            echo Color::YELLOW . "ต้องการ commit และ push การเปลี่ยนแปลงหรือไม่? (y/n) [y]: " . Color::RESET;
            $shouldCommit = strtolower(trim(fgets(STDIN)));
            
            if ($shouldCommit !== 'n' && $shouldCommit !== 'no') {
                $this->info("{$step}. กำลัง commit และ push...");
                $this->commitAndPush($projectName);
            }
        }
        
        echo "\n";
        $this->success("✓ ตั้งค่าโปรเจคเสร็จสมบูรณ์!");
        echo "\n";
        
        // แสดงสรุป
        echo Color::GREEN . Color::BOLD . "สรุปข้อมูลโปรเจค:\n" . Color::RESET;
        echo Color::WHITE . "  ชื่อโปรเจค: " . Color::CYAN . $projectName . Color::RESET . "\n";
        echo Color::WHITE . "  Composer name: " . Color::CYAN . "{$vendorName}/{$projectName}" . Color::RESET . "\n";
        echo Color::WHITE . "  ชื่อแอป: " . Color::CYAN . $appName . Color::RESET . "\n";
        echo Color::WHITE . "  Database: " . Color::CYAN . $dbName . Color::RESET . "\n";
        echo Color::WHITE . "  APP_KEY: " . Color::CYAN . $appKey . Color::RESET . "\n";
        echo "\n";

        // 17. เปลี่ยนชื่อโฟลเดอร์โปรเจค (ถ้าผู้ใช้เลือก)
        // ต้องทำท้ายสุดเท่านั้น เพราะโค้ดส่วนใหญ่ใช้ __DIR__ ในการอ้าง path
        if ($shouldRenameFolder) {
            $parentDir = dirname($currentFolderPath);
            $newFolderPath = $parentDir . DIRECTORY_SEPARATOR . $projectName;

            echo "\n";
            $this->info("กำลังเปลี่ยนชื่อโฟลเดอร์โปรเจค...");

            if (file_exists($newFolderPath)) {
                $this->warning("มีโฟลเดอร์ชื่อ '{$projectName}' อยู่แล้วใน {$parentDir} (ข้ามการเปลี่ยนชื่อ)");
                return;
            }

            // Windows อาจล็อคไฟล์บางอย่าง ทำให้ rename ไม่สำเร็จ
            if (@rename($currentFolderPath, $newFolderPath)) {
                $this->success("เปลี่ยนชื่อโฟลเดอร์สำเร็จ: {$newFolderPath}");
                $this->info("ขั้นตอนถัดไป: cd \"{$newFolderPath}\" แล้วรันคำสั่งต่อไปตามต้องการ");
            } else {
                $error = error_get_last();
                $detail = $error['message'] ?? 'unknown error';
                $this->warning("ไม่สามารถเปลี่ยนชื่อโฟลเดอร์อัตโนมัติได้ ({$detail})");
                $this->info("คุณสามารถเปลี่ยนชื่อโฟลเดอร์ด้วยตัวเองได้ภายหลัง: '{$currentFolderName}' -> '{$projectName}'");
            }
        }
    }
    
    private function updateComposerJson(string $vendor, string $project, string $description): void
    {
        $composerFile = __DIR__ . '/composer.json';
        
        if (!file_exists($composerFile)) {
            $this->error("ไม่พบไฟล์ composer.json");
            return;
        }
        
        $composer = json_decode(file_get_contents($composerFile), true);
        
        $composer['name'] = strtolower($vendor) . '/' . strtolower($project);
        if (!empty($description)) {
            $composer['description'] = $description;
        }
        
        file_put_contents($composerFile, json_encode($composer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE));
        
        $this->success("  [OK] อัปเดต composer.json แล้ว");
    }
    
    private function createEnvFile(string $appName, string $dbName, string $dbUser, string $dbPassword): void
    {
        $envExample = __DIR__ . '/.env.example';
        $envFile = __DIR__ . '/.env';
        
        if (!file_exists($envExample)) {
            $this->error("ไม่พบไฟล์ .env.example");
            return;
        }
        
        $content = file_get_contents($envExample);
        
        // แทนที่ค่าต่างๆ
        $content = preg_replace('/APP_NAME=.*/', 'APP_NAME="' . $appName . '"', $content);
        $content = preg_replace('/DB_DATABASE=.*/', 'DB_DATABASE=' . $dbName, $content);
        $content = preg_replace('/DB_USERNAME=.*/', 'DB_USERNAME=' . $dbUser, $content);
        $content = preg_replace('/DB_PASSWORD=.*/', 'DB_PASSWORD=' . $dbPassword, $content);
        
        file_put_contents($envFile, $content);
        
        $this->success("  [OK] สร้างไฟล์ .env แล้ว");
    }
    
    private function generateAppKey(): string
    {
        return bin2hex(random_bytes(16));
    }
    
    private function updateEnvKey(string $key): void
    {
        $envFile = __DIR__ . '/.env';
        
        if (!file_exists($envFile)) {
            $this->error("ไม่พบไฟล์ .env");
            return;
        }
        
        $content = file_get_contents($envFile);
        $content = preg_replace('/APP_KEY=.*/', 'APP_KEY=' . $key, $content);
        
        file_put_contents($envFile, $content);
        
        $this->success("  [OK] สร้าง APP_KEY แล้ว");
    }
    
    private function updateReadme(string $projectName, string $appName, string $description): void
    {
        $readmeFile = __DIR__ . '/README.md';
        
        if (!file_exists($readmeFile)) {
            $this->warning("  [!] ไม่พบไฟล์ README.md");
            return;
        }
        
        $content = file_get_contents($readmeFile);
        
        // เปลี่ยนชื่อโปรเจค
