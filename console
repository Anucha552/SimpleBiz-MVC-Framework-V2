    private function showDatabaseTables(): void
    {
        $this->info("กำลังแสดงรายการตารางในฐานข้อมูล...");
        
        try {
            $config = require __DIR__ . '/config/database.php';
            
            // รองรับทั้งรูปแบบการกำหนดค่าแบบเก่าและแบบใหม่
            if (isset($config['connections'])) {
                $dbConfig = $config['connections'][$config['default']];
            } else {
                $dbConfig = $config;
            }
            
            // สร้างการเชื่อมต่อ PDO
            $pdo = new PDO(
                "mysql:host={$dbConfig['host']};dbname={$dbConfig['database']}",
                $dbConfig['username'],
                $dbConfig['password']
            );
            
            // ดึงรายการตาราง
            $stmt = $pdo->query("SHOW TABLES");
            $tables = $stmt->fetchAll(PDO::FETCH_COLUMN);
            
            // ตรวจสอบว่าพบตารางหรือไม่
            if (empty($tables)) {
                $this->warning("ไม่พบตารางในฐานข้อมูล");
                return;
            }
            
            echo "\n" . Color::GREEN . "[DATABASE] ตารางทั้งหมด (" . count($tables) . " ตาราง):" . Color::RESET . "\n";
            echo str_repeat("─", 50) . "\n";
            
            foreach ($tables as $index => $table) {
                // ดึงจำนวนแถวในตาราง
                $countStmt = $pdo->query("SELECT COUNT(*) FROM `{$table}`");
                $rowCount = $countStmt->fetchColumn();
                
                echo Color::CYAN . sprintf("%2d. ", $index + 1) . Color::WHITE . $table . 
                     Color::GRAY . " ({$rowCount} แถว)" . Color::RESET . "\n";
            }
            
            echo str_repeat("─", 50) . "\n";
            $this->success("แสดงรายการตารางเรียบร้อยแล้ว \n");
            
        } catch (Exception $e) {
            echo "\n";
            echo "┌─ Database Connection Error ─────────────────────────┐\n";
            $this->error("ไม่สามารถเชื่อมต่อฐานข้อมูล: " . $e->getMessage());
            echo "│\n";
            $this->warning("[TIP] คำแนะนำ:");
            $this->info("   1. ตรวจสอบว่าเปิด MySQL/MariaDB แล้วหรือไม่");
            $this->info("   2. ตรวจสอบการตั้งค่าใน .env ไฟล์");
            $this->info("   3. ตรวจสอบว่าสร้าง database แล้วหรือไม่");
            echo "└──────────────────────────────────────────────────────┘\n";
            echo "\n";
            
            // Log error
            try {
                (new \App\Core\Logger())->error('Database connection failed', [
                    'command' => 'db:show',
                    'error' => $e->getMessage(),
                ]);
            } catch (\Exception $logError) {
                // Ignore logging errors  
            }
        }
    }
    
