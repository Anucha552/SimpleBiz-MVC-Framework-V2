    private function changeGitRemote(string $newUrl): void
    {
        // ตรวจสอบว่ามี .git directory อยู่หรือไม่
        if (!is_dir(__DIR__ . '/.git')) {
            $this->warning("  [!] ไม่พบ Git repository, ข้ามขั้นตอนนี้");
            return;
        }
        
        // ลบ remote origin เดิม
        exec("git remote remove origin 2>&1", $output, $returnCode);
        
        // เพิ่ม remote ใหม่
        exec("git remote add origin {$newUrl} 2>&1", $output, $returnCode);
        
        if ($returnCode === 0) {
            $this->success("  [OK] เปลี่ยน Git remote เป็น {$newUrl} แล้ว");
        } else {
            $this->error("  [X] ไม่สามารถเปลี่ยน Git remote ได้");
        }
    }
    
    private function reinitGit(string $newUrl): void
    {
        // ลบ .git directory เดิม
        if (is_dir(__DIR__ . '/.git')) {
            $this->removeDirectory(__DIR__ . '/.git');
            $this->success("  [OK] ลบ Git repository เดิมแล้ว");
        }
        
        // เริ่มต้น Git ใหม่
        exec("git init 2>&1", $output, $returnCode);
        
        if ($returnCode !== 0) {
            $this->error("  [X] ไม่สามารถเริ่มต้น Git ได้");
            return;
        }
        
        // เพิ่ม remote
        exec("git remote add origin {$newUrl} 2>&1");
        
        // สร้าง branch main
        exec("git branch -M main 2>&1");
        
        $this->success("  [OK] เริ่มต้น Git repository ใหม่แล้ว");
    }
    
    private function commitAndPush(string $projectName): void
    {
        // เพิ่มไฟล์ทั้งหมด
        exec("git add . 2>&1", $output, $returnCode);
        
        if ($returnCode !== 0) {
            $this->error("  [X] ไม่สามารถ add ไฟล์ได้");
            return;
        }
        
        // Commit
        $commitMessage = "Initial setup for {$projectName}";
        exec('git commit -m "' . $commitMessage . '" 2>&1', $output, $returnCode);
        
        if ($returnCode !== 0) {
            $this->warning("  [!] ไม่มีการเปลี่ยนแปลงให้ commit หรือเกิดข้อผิดพลาด");
            return;
        }
        
        $this->success("  [OK] Commit สำเร็จ");
        
        // Push
        echo Color::CYAN . "  กำลัง push ไปยัง GitHub..." . Color::RESET . "\n";
        passthru("git push -u origin main 2>&1", $returnCode);
        
        if ($returnCode === 0) {
            $this->success("  [OK] Push สำเร็จ!");
        } else {
            $this->warning("  [!] Push ไม่สำเร็จ (อาจต้อง authenticate หรือสร้าง repository บน GitHub ก่อน)");
            $this->info("    คุณสามารถ push เองภายหลังด้วย: git push -u origin main");
        }
    }
    
    private function removeDirectory(string $dir): void
    {
        if (!is_dir($dir)) {
            return;
        }
        
        $files = array_diff(scandir($dir), ['.', '..']);
        
        foreach ($files as $file) {
            $path = $dir . '/' . $file;
            is_dir($path) ? $this->removeDirectory($path) : unlink($path);
        }
        
        rmdir($dir);
    }
    
    private function runServer(array $args): void
    {
        $host = $args[0] ?? 'localhost';
        $port = $args[1] ?? '8000';
        
        $this->info("กำลังเริ่มเซิร์ฟเวอร์สำหรับพัฒนา...");
        $this->success("เซิร์ฟเวอร์ทำงานที่ http://{$host}:{$port}");
        $this->info("กด Ctrl+C เพื่อหยุด");
        echo "\n";

        // บน Windows คำสั่ง `php` อาจชี้ไปที่ php.bat (shim) ทำให้กด Ctrl+C แล้วขึ้น
        // "Terminate batch job (Y/N)?" ดังนั้นให้เรียก php.exe โดยตรงจาก PHP_BINARY
        $phpBinary = PHP_BINARY;
        $phpBinaryQuoted = (str_contains($phpBinary, ' ') ? '"' . $phpBinary . '"' : $phpBinary);

        passthru("{$phpBinaryQuoted} -S {$host}:{$port} -t public");
    }
    
    private function runMigrations(array $args): void
    {
        // โหลด MigrationRunner
        try {
            $runner = new \App\Core\MigrationRunner();
            
            // ตรวจสอบ --path option
            $modulePath = null;
            foreach ($args as $arg) {
                if (strpos($arg, '--path=') === 0) {
                    $modulePath = substr($arg, 7);
                }
            }
            
            // ตรวจสอบ database connection first
            if ($modulePath) {
                $runner->setModule($modulePath);
                $this->info("โมดูล: $modulePath");
            }
            
            $this->info("กำลังรัน migrations...");
            echo Color::WHITE . "-------------------" . Color::RESET . "\n";
            
            $result = $runner->run();
            echo "\n";
            $this->success($result['message'] . "\n");
            
        } catch (\Exception $e) {
            echo "\n";
            echo "┌─ Console Error ─────────────────────────────────────┐\n";
            $this->error("เกิดข้อผิดพลาด: " . $e->getMessage());
            $this->error("ไฟล์: " . $e->getFile());
            $this->error("บรรทัด: " . $e->getLine());
            echo "└──────────────────────────────────────────────────────┘\n";
            echo "\n";
            
            // Log error
            try {
                (new \App\Core\Logger())->error('Console command error', [
                    'command' => 'migrate',
                    'error' => $e->getMessage(),
                    'trace' => $e->getTraceAsString(),
                ]);
            } catch (\Exception $logError) {
                // Ignore logging errors
            }
            
            exit(1);
        }
    }
    
