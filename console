            $this->info("วิธีใช้: php console make:controller ControllerName \n");
            return;
        }

        // ถามว่าจะสร้าง Controller WEB หรือ API
        echo Color::CYAN . "เลือกประเภท Controller:\n" . Color::RESET;
        echo Color::WHITE . "  1. Web Controller (จัดการหน้าเว็บ)\n" . Color::RESET;
        echo Color::WHITE . "  2. API Controller (จัดการ API)\n" . Color::RESET;
        echo Color::CYAN . "เลือก (1/2): " . Color::RESET;
        $choice = trim(fgets(STDIN));

        // ตรวจสอบคำตอบว่าเป็น 1 หรือ 2
        $apiOrWeb = '';
        if ($choice === '1') {
            $apiOrWeb = 'Web';
        } elseIf ($choice === '2') {
            $apiOrWeb = 'Api';
        } else {
            echo "\n";
            $this->error("ตัวเลือกไม่ถูกต้อง, กรุณาเลือก 1 หรือ 2 \n");
            return;
        }
        
        // เพิ่มคำว่า Controller ถ้ายังไม่มี
        $name = $args[0];
        if (!str_ends_with($name, 'Controller')) {
            $name .= 'Controller';
        }
        
        $path = __DIR__ . "/app/Controllers/{$apiOrWeb}/{$name}.php";
        
        // ตรวจสอบว่ามีไฟล์อยู่แล้วหรือไม่
        if (file_exists($path)) {
            echo "\n";
            $this->error("Controller นี้มีอยู่แล้ว!\n");
            return;
        }
        
        try {
            // สร้างโฟลเดอร์ถ้ายังไม่มี
            $dir = dirname($path);
            if (!is_dir($dir)) {
                mkdir($dir, 0755, true);
            }
            
            // สร้างไฟล์ controller
            $template = '';
            if ($apiOrWeb === 'Web') {
                $template = $this->getWebControllerTemplate($name);
            } else {
                $template = $this->getApiControllerTemplate($name);
            }
            if (file_put_contents($path, $template) === false) {
                throw new \Exception("ไม่สามารถเขียนไฟล์ได้ กรุณาตรวจสอบสิทธิ์การเขียนไฟล์");
            }
            
            echo "\n";
            $this->success("สร้าง Controller สำเร็จ: app/Controllers/{$apiOrWeb}/{$name}.php \n");
        } catch (\Exception $e) {
            echo "\n";
            echo "┌─ Create Controller Error ───────────────────────────┐\n";
            $this->error("เกิดข้อผิดพลาด: " . $e->getMessage());
            $this->warning("[TIP] คำแนะนำ: ตรวจสอบสิทธิ์การเขียนไฟล์");
