    // ==================== Helper Methods ====================
    
    /**
     * ถามยืนยันจากผู้ใช้ (Yes/No)
     * @param string $message ข้อความที่จะถาม
     * @param bool $default คำตอบเริ่มต้นถ้ากด Enter เลย
     * @return bool true ถ้าตอบ yes, false ถ้าตอบ no
     */
    private function confirm(string $message, bool $default = false): bool
    {
        $defaultText = $default ? 'Y/n' : 'y/N';
        echo Color::YELLOW . "[?] {$message} [{$defaultText}]: " . Color::RESET;
        
        $input = strtolower(trim(fgets(STDIN)));
        
        // ถ้าไม่ได้ใส่อะไร ใช้ค่า default
        if (empty($input)) {
            return $default;
        }
        
        // ตรวจสอบว่าตอบ yes หรือไม่ (รองรับภาษาไทย)
        return in_array($input, ['y', 'yes', 'ใช่']);
    }
    
    /**
     * ตรวจสอบว่ามี --force หรือ -f flag หรือไม่
     * @param array $args รายการ arguments
     * @return bool true ถ้ามี force flag
     */
    private function hasForceFlag(array $args): bool
    {
        return in_array('--force', $args) || in_array('-f', $args);
    }
    
    /**
     * ตรวจสอบการเชื่อมต่อฐานข้อมูล
     * @return bool true ถ้าเชื่อมต่อสำเร็จ, false ถ้าเชื่อมต่อไม่ได้
     */
    private function checkDatabaseConnection(): bool
    {
        try {
            // โหลดค่าคอนฟิกฐานข้อมูล
            $config = require __DIR__ . '/config/database.php';
            
            // รองรับทั้งรูปแบบเก่า (แบบ flat) และรูปแบบใหม่ (แบบมี connections)
            if (isset($config['connections'])) {
                $dbConfig = $config['connections'][$config['default']];
            } else {
                $dbConfig = $config;
            }
            
            $pdo = new PDO(
                "mysql:host={$dbConfig['host']};dbname={$dbConfig['database']}",
                $dbConfig['username'],
                $dbConfig['password'],
                [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]
            );
            
            return true;
        } catch (Exception $e) {
            $this->error("ไม่สามารถเชื่อมต่อฐานข้อมูล");
            echo Color::RED . "Error: " . $e->getMessage() . Color::RESET . "\n\n";
            
            echo Color::YELLOW . "[TIP] วิธีแก้ไข:" . Color::RESET . "\n";
            echo "  1. ตรวจสอบว่า MySQL server ทำงานอยู่\n";
            echo "  2. ตรวจสอบค่า DB_* ในไฟล์ .env\n";
            echo "  3. สร้าง database: CREATE DATABASE database_name;\n";
            echo "  4. ตรวจสอบ username/password ในไฟล์ .env\n\n";
            
            return false;
        }
    }
    
    /**
     * ค้นหาคำสั่งที่คล้ายกับที่ผู้ใช้พิมพ์ (สำหรับแนะนำเมื่อพิมพ์ผิด)
     * @param string $input คำสั่งที่ผู้ใช้พิมพ์
     * @return array รายการคำสั่งที่คล้ายกัน (สูงสุด 5 คำสั่ง)
     */
    private function findSimilarCommands(string $input): array
    {
        $allCommands = array_keys($this->commands);
        $suggestions = [];
        
        foreach ($allCommands as $cmd) {
            // ตรวจสอบว่าคำสั่งขึ้นต้นด้วยคำที่พิมพ์หรือไม่
            if (strpos($cmd, $input) === 0) {
                $suggestions[] = $cmd;
            }
            // หรือคำนวณ Levenshtein distance เพื่อหาคำที่สะกดใกล้เคียง
            // (ระยะห่าง <= 2 ตัวอักษร ถือว่าคล้ายกัน)
            elseif (levenshtein($input, $cmd) <= 2) {
                $suggestions[] = $cmd;
            }
        }
        
        // คืนค่าสูงสุด 5 คำสั่งที่คล้ายกัน
        return array_slice($suggestions, 0, 5);
    }
    
