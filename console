        }
        
        $tableName = $args[0];
        $this->info("กำลังแสดงโครงสร้างของตาราง '{$tableName}'...");
        
        try {
            $config = require __DIR__ . '/config/database.php';
            
            // รองรับทั้งรูปแบบการกำหนดค่าแบบเก่าและแบบใหม่
            if (isset($config['connections'])) {
                $dbConfig = $config['connections'][$config['default']];
            } else {
                $dbConfig = $config;
            }
            
            $pdo = new PDO(
                "mysql:host={$dbConfig['host']};dbname={$dbConfig['database']}",
                $dbConfig['username'],
                $dbConfig['password']
            );
            
            // Check if table exists
            $stmt = $pdo->query("SHOW TABLES LIKE '{$tableName}'");
            if ($stmt->rowCount() === 0) {
                $this->error("ไม่พบตาราง '{$tableName}'");
                return;
            }
            
            // ดึงคอลัมน์
            $stmt = $pdo->query("DESCRIBE `{$tableName}`");
            $columns = $stmt->fetchAll(PDO::FETCH_ASSOC);
            
            // Get indexes
            $stmt = $pdo->query("SHOW INDEX FROM `{$tableName}`");
            $indexes = $stmt->fetchAll(PDO::FETCH_ASSOC);
            
            // Get row count
            $stmt = $pdo->query("SELECT COUNT(*) FROM `{$tableName}`");
            $rowCount = $stmt->fetchColumn();
            
            echo "\n" . Color::GREEN . "[TABLE] {$tableName}" . Color::RESET . "\n";
            echo Color::GRAY . "จำนวนแถว: {$rowCount}" . Color::RESET . "\n\n";
            
            // Display columns with proper alignment
            echo Color::YELLOW . "คอลัมน์:" . Color::RESET . "\n";
            echo str_repeat("─", 90) . "\n";
            
            // Header - use English to avoid multi-byte issues
            echo str_pad("Column", 25) . str_pad("Type", 25) . str_pad("Null", 8) . str_pad("Key", 8) . "Default\n";
            echo str_repeat("─", 90) . "\n";
            
            // Data rows
            foreach ($columns as $column) {
                // Truncate long values
                $field = strlen($column['Field']) > 24 ? substr($column['Field'], 0, 21) . '...' : $column['Field'];
                $type = strlen($column['Type']) > 24 ? substr($column['Type'], 0, 21) . '...' : $column['Type'];
                $default = $column['Default'] ?? 'NULL';
                $default = strlen($default) > 20 ? substr($default, 0, 17) . '...' : $default;
                $key = $column['Key'] ?: '-';
                
                // Output with str_pad for consistent alignment
                echo str_pad($field, 25) . str_pad($type, 25) . str_pad($column['Null'], 8) . str_pad($key, 8) . $default . "\n";
            }
            
            echo str_repeat("─", 90) . "\n";
            
            // Display indexes
            if (!empty($indexes)) {
                echo "\n" . Color::YELLOW . "Indexes:" . Color::RESET . "\n";
                echo str_repeat("─", 90) . "\n";
                
                $indexGroups = [];
                foreach ($indexes as $index) {
                    $indexGroups[$index['Key_name']][] = $index['Column_name'];
                }
                
                // Header - use str_pad for consistent alignment
                echo str_pad("Index Name", 40) . "Columns\n";
                echo str_repeat("─", 90) . "\n";
                
                foreach ($indexGroups as $indexName => $cols) {
                    $colsText = implode(', ', $cols);
                    
                    // Truncate if too long
                    $nameDisplay = strlen($indexName) > 39 ? substr($indexName, 0, 36) . '...' : $indexName;
                    $colsText = strlen($colsText) > 45 ? substr($colsText, 0, 42) . '...' : $colsText;
                    
                    echo str_pad($nameDisplay, 40) . $colsText . "\n";
                }
                
                echo str_repeat("─", 90) . "\n";
            }
            
            echo "\n";
            $this->success("แสดงโครงสร้างตารางเรียบร้อยแล้ว \n");
            
        } catch (Exception $e) {
            $this->error("เกิดข้อผิดพลาด: " . $e->getMessage() . "\n");
        }
    }
    
    private function resetMigrations(array $args = []): void
    {
        // Check database connection first
        if (!$this->checkDatabaseConnection()) {
            exit(1);
        }
        
        echo Color::RED . "[WARNING] จะ rollback migrations ทั้งหมด!" . Color::RESET . "\n\n";
        
        // Require confirmation unless --force flag
        if (!$this->hasForceFlag($args)) {
            if (!$this->confirm("คุณแน่ใจหรือไม่?")) {
                $this->warning("ยกเลิกการทำงาน");
                return;
            }
            echo "\n";
        }
        
        $this->info("กำลัง rollback migrations ทั้งหมด...");
        
        $runner = new \App\Core\MigrationRunner();

        // Rollback all batches by repeatedly rolling back 1 batch until no more remain.
        $maxLoops = 200; // Safety limit
        $loops = 0;
        $totalRolledBack = 0;

        while ($loops < $maxLoops) {
            $loops++;
            $result = $runner->rollback(1);
            $rolledBack = $result['rolled_back'] ?? [];
            $count = is_array($rolledBack) ? count($rolledBack) : 0;
            $totalRolledBack += $count;

            if ($count === 0) {
                break;
            }
        }

        if ($loops >= $maxLoops) {
            $this->warning("หยุดการ rollback เนื่องจากถึงขีดจำกัดความปลอดภัย ({$maxLoops} รอบ)");
        }
        
        $this->success("Reset migrations เรียบร้อยแล้ว (rollback {$totalRolledBack} migrations)");
    }
    
    private function refreshMigrations(array $args = []): void
    {
        // ตรวจสอบการเชื่อมต่อฐานข้อมูลก่อน
        if (!$this->checkDatabaseConnection()) {
            exit(1);
        }
        
        echo Color::RED . "[WARNING] จะ reset และ migrate ใหม่ทั้งหมด!" . Color::RESET . "\n\n";
        
        // Require confirmation unless --force flag
        if (!$this->hasForceFlag($args)) {
            if (!$this->confirm("คุณแน่ใจหรือไม่?")) {
                $this->warning("ยกเลิกการทำงาน");
                return;
            }
            echo "\n";
        }
        
        $this->info("กำลัง refresh migrations (reset + migrate)...");
        
        // Parse args
        $seed = in_array('--seed', $args);
        $force = $this->hasForceFlag($args);

        // Reset
        $this->resetMigrations($force ? ['--force'] : []);
        
        echo "\n";
        
        // Migrate
        $this->runMigrations([]);
        
        // Seed if requested
        if ($seed) {
            echo "\n";
            $this->info("กำลัง seed ข้อมูล...");
            $this->runSeeders([]);
        }
        
        echo "\n";
        $this->success("Refresh migrations เรียบร้อยแล้ว" . ($seed ? " (รวม seeding)" : ""));
    }
    
    // ==================== Cache Commands ====================
    
    private function warmCache(): void
    {
        $this->info("กำลังเตรียม cache...");
        
        $cacheDir = __DIR__ . '/storage/cache';
        
        // Create cache directories if not exist
        $dirs = ['routes', 'config', 'views'];
        foreach ($dirs as $dir) {
            $path = $cacheDir . '/' . $dir;
            if (!is_dir($path)) {
                mkdir($path, 0755, true);
            }
        }
        
        // Cache routes - เก็บเฉพาะข้อมูล metadata ไม่ใช่ require file
        $this->info("  - กำลัง cache routes...");
        $routeMetadata = [
            'web' => file_exists(__DIR__ . '/routes/web.php'),
            'api' => file_exists(__DIR__ . '/routes/api.php'),
            'cached_at' => time(),
        ];
        
        file_put_contents(
            $cacheDir . '/routes/routes_cached.php',
            "<?php\nreturn " . var_export($routeMetadata, true) . ";"
        );
        
        // Cache config
        $this->info("  - กำลัง cache config...");
        $configFiles = glob(__DIR__ . '/config/*.php');
        $cachedConfig = [];
        
        foreach ($configFiles as $file) {
            $key = basename($file, '.php');
            $cachedConfig[$key] = require $file;
        }
        
        file_put_contents(
            $cacheDir . '/config/config_cached.php',
            "<?php\nreturn " . var_export($cachedConfig, true) . ";"
        );
        
        $this->success("เตรียม cache เรียบร้อยแล้ว");
    }
    
