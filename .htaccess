# การตั้งค่า Apache สำหรับ SimpleBiz MVC Framework
#
# จุดประสงค์: เปลี่ยนเส้นทางคำขอทั้งหมดไปยัง public/index.php
# วางไฟล์นี้ในโฟลเดอร์รากของโปรเจค

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # เปลี่ยนเส้นทางไปยังโฟลเดอร์ public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]
</IfModule>
