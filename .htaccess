# การตั้งค่า Apache สำหรับ SimpleBiz MVC Framework (root)
# ปรับให้ไม่พึ่งชื่อโฟลเดอร์โปรเจคแบบตายตัว เพื่อรองรับการเปลี่ยนชื่อโฟลเดอร์

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ถ้าคำขอชี้ไปยังไฟล์หรือโฟลเดอร์จริง ให้เสิร์ฟตรงๆ
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # ถ้า URI มี /public/ อยู่แล้ว (ติดตั้งใน subfolder) ให้ไม่ต้อง rewrite
    RewriteCond %{REQUEST_URI} /public/ [NC]
    RewriteRule ^ - [L]

    # ส่งคำขอทั้งหมดที่เหลือไปยังโฟลเดอร์ public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# กำหนด index file
DirectoryIndex public/index.php
