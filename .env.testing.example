# Example .env.testing - copy to .env.testing and edit as needed for local tests
APP_ENV=testing
APP_DEBUG=true

# ใช้ sqlite สำหรับการทดสอบในเครื่องโดยค่าเริ่มต้น
DB_CONNECTION=sqlite
DB_DATABASE=storage/test.sqlite

# หากต้องการใช้ MySQL สำหรับการทดสอบ ให้ยกเลิกการคอมเมนต์
# และตั้งค่าด้านล่าง
#DB_CONNECTION=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=storage/simplebiz_test.sqlite
#DB_USERNAME=root
#DB_PASSWORD=secret

# Logging
LOG_LEVEL=debug
