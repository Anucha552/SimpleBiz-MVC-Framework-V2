# Example .env.testing - copy to .env.testing and edit as needed for local tests
APP_ENV=testing
APP_DEBUG=true

# Use sqlite for local testing by default
DB_CONNECTION=sqlite
DB_DATABASE=storage/test.sqlite

# If you prefer MySQL for tests, uncomment and set values below
#DB_CONNECTION=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=simplebiz_test
#DB_USERNAME=root
#DB_PASSWORD=secret

# Logging
LOG_LEVEL=debug
