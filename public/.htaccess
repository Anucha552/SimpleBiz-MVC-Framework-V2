# การตั้งค่า Apache สำหรับโฟลเดอร์ Public
#
# จุดประสงค์: รูปแบบ Front controller - เปลี่ยนเส้นทางคำขอทั้งหมดผ่าน index.php
# วางไฟล์นี้ในโฟลเดอร์ public/

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # เปลี่ยนเส้นทาง Trailing Slashes ถ้าไม่ใช่โฟลเดอร์...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]
    
    # ส่งคำขอไปยัง Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ส่วนหัวความปลอดภัย
<IfModule mod_headers.c>
    # ป้องกัน clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # ป้องกันการตรวจสอบ MIME-type
    Header always set X-Content-Type-Options "nosniff"
    
    # เปิดใช้งานการป้องกัน XSS
    Header always set X-XSS-Protection "1; mode=block"
    
    # นโยบาย Referrer
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# การตั้งค่าความปลอดภัยของ PHP
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log ../storage/logs/php-errors.log
</IfModule>
